{
  "flavor_texts": [
	{
	  "phases": [
        "daily"
	  ],
	  "text": "教学楼走廊的风有点凉，你抱着书加快了脚步。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "text": "午后的阳光斜斜照进教室，你差点在最后一排睡着。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "text": "今天的作业不算难，但就是特别耗时间。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "text": "下课铃一响，大家像潮水一样涌向食堂。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "text": "晚自习结束时，校园广播正放着一首老歌。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "text": "你在便利店门口犹豫了半天，最后还是买了那杯咖啡。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "text": "图书馆靠窗的位置又被抢了，你只好坐在角落。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "text": "今天路过操场，看见好几支社团队伍在排练。"
	},
	{
	  "phases": [
        "weekend"
	  ],
	  "text": "周末的宿舍楼安静了不少，连脚步声都变得稀疏。"
	},
	{
	  "phases": [
        "weekend"
	  ],
	  "text": "你睡到自然醒，窗外的天已经亮得刺眼。"
	},
	{
	  "phases": [
        "weekend"
	  ],
	  "text": "和室友去校外吃了顿好的，心情跟着亮起来。"
	},
	{
	  "phases": [
        "weekend"
	  ],
	  "text": "你把堆了几天的衣服洗完，阳台一下子满了。"
	},
	{
	  "phases": [
        "weekend"
	  ],
	  "text": "傍晚绕着校园慢慢走了一圈，风很舒服。"
	},
	{
	  "phases": [
        "review"
	  ],
	  "text": "复习资料铺满了桌面，你一时间不知道该从哪页开始。"
	},
	{
	  "phases": [
        "review"
	  ],
	  "text": "自习室的空调有点冷，但没人愿意离开座位。"
	},
	{
	  "phases": [
        "review"
	  ],
	  "text": "你把一门课从头过了一遍，终于不再那么慌。"
	},
	{
	  "phases": [
        "review"
	  ],
	  "text": "打印店门口排着长队，大家都抱着一叠讲义。"
	},
	{
	  "phases": [
        "review"
	  ],
	  "text": "夜里回宿舍时，楼道里还有人小声背书。"
	},
	{
	  "phases": [
        "exam"
	  ],
	  "text": "考场外的走廊安静得反常，只剩翻书声。"
	},
	{
	  "phases": [
        "exam"
	  ],
	  "text": "你盯着试卷最后一道题，笔尖悬在半空很久。"
	},
	{
	  "phases": [
        "exam"
	  ],
	  "text": "走出考场后，大家互相看了看，默契地都没对答案。"
	},
	{
	  "phases": [
        "exam"
	  ],
	  "text": "今天又是一门，书包里的笔记越翻越皱。"
	},
	{
	  "phases": [
        "exam"
	  ],
	  "text": "你喝了第三杯咖啡，眼睛却还是发酸。"
	},
	{
	  "phases": [
        "military"
	  ],
	  "text": "口令声在操场上回荡，大家的动作逐渐整齐起来。"
	},
	{
	  "phases": [
        "military"
	  ],
	  "text": "太阳很毒，鞋底都像在发烫。"
	},
	{
	  "phases": [
        "military"
	  ],
	  "text": "晚点名结束后，整层宿舍都在抱怨腿酸。"
	},
	{
	  "phases": [
        "military"
	  ],
	  "text": "教官难得让你们提前休息，队伍里一阵欢呼。"
	},
	{
	  "phases": [
        "holiday_winter"
	  ],
	  "text": "家里的饭桌总是比学校热闹，也更让人放松。"
	},
	{
	  "phases": [
        "holiday_winter"
	  ],
	  "text": "你裹着毯子刷手机，不知不觉就到了深夜。"
	},
	{
	  "phases": [
        "holiday_winter"
	  ],
	  "text": "亲戚问起成绩时，你笑着把话题带了过去。"
	},
	{
	  "phases": [
        "holiday_winter"
	  ],
	  "text": "和老同学见了一面，大家都比从前成熟了些。"
	},
	{
	  "phases": [
        "holiday_summer"
	  ],
	  "text": "蝉鸣从早响到晚，空气里都是盛夏的味道。"
	},
	{
	  "phases": [
        "holiday_summer"
	  ],
	  "text": "你在空调房里待了一整天，直到傍晚才出门。"
	},
	{
	  "phases": [
        "holiday_summer"
	  ],
	  "text": "夜里和朋友吃了路边摊，聊到很晚才散。"
	},
	{
	  "phases": [
        "holiday_summer"
	  ],
	  "text": "你翻看这学期的照片，忽然有点想念校园。"
	},
	{
	  "phases": [
		"daily",
        "weekend"
	  ],
	  "requires": [
        "gamer_friend"
	  ],
	  "text": "{roommate_gamer}在群里发来一句：\"今晚开黑，速来。\""
	},
	{
	  "phases": [
		"daily",
        "review"
	  ],
	  "requires": [
        "studious_friend"
	  ],
	  "text": "{roommate_studious}又比你先到图书馆，桌上已经摊开了三本书。"
	},
	{
	  "phases": [
		"daily",
        "weekend"
	  ],
	  "requires": [
        "in_relationship"
	  ],
	  "text": "TA发来一张今天的天空照片：\"这云很好看，想到你了。\""
	},
	{
	  "phases": [
        "daily"
	  ],
	  "requires": [
        "student_union"
	  ],
	  "text": "学生会群消息不断，你刚放下手机又弹出新通知。"
	},
	{
	  "phases": [
        "daily"
	  ],
	  "requires": [
        "tech_club"
	  ],
	  "text": "技术社群里又有人在讨论新项目，你默默记下了几个关键词。"
	},
	{
	  "phases": [
		"daily",
        "weekend"
	  ],
	  "conditions": {
		"mental": {
		  "max": 30
		}
	  },
	  "text": "今天做什么都提不起劲，连说话都觉得费力。"
	},
	{
	  "phases": [
		"daily",
        "weekend"
	  ],
	  "conditions": {
		"health": {
		  "max": 25
		}
	  },
	  "text": "你一整天都有些疲惫，走几步路就想停下来。"
	},
	{
	  "phases": [
		"daily",
        "weekend"
	  ],
	  "conditions": {
		"living_money": {
		  "max": 450
		}
	  },
	  "text": "打开付款码前，你下意识先算了算余额。"
	},
	{
	  "phases": [
		"daily",
        "review"
	  ],
	  "conditions": {
		"gpa": {
		  "min": 80
		}
	  },
	  "text": "课代表来问你借笔记，你忽然意识到自己真的进步了。"
	},
	{
	  "phases": [
		"daily",
        "weekend"
	  ],
	  "conditions": {
		"social": {
		  "min": 75
		}
	  },
	  "text": "消息提醒几乎没停过，你今天回消息回到手酸。"
	}
  ]
}
