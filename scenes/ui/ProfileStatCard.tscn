[gd_scene format=3]

[node name="ProfileStatCard" type="PanelContainer"]
custom_minimum_size = Vector2(0, 108)

[node name="CardMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="CardMargin"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="TitleLabel" type="Label" parent="CardMargin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 12

[node name="ValueLabel" type="Label" parent="CardMargin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 22

[node name="NoteLabel" type="Label" parent="CardMargin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
autowrap_mode = 2
